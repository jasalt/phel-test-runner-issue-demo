(ns app\core)

(defn plus-one [x]
  "See test in "
  (+ 1 x))

(defn main []
  (println "Writing file \"foo.txt\" with Amp\\File\\write")
  (php/amp\file\write "foo.txt" "WORKS!")
  (println "Reading it with Amp\\File\\read")
  (println (php/amp\file\read "foo.txt"))
  )


(main)  ; this has to be commented for test runner to run correctly, else getting:
